  "scripts": {
    "start": "webpack-dev-server --mode development --open --hot --port 8080",
    "build-dev": "webpack --mode development",
    "build": "webpack --mode production",
    "lint": "tsc --noEmit && eslint --ext .ts,.tsx src/",
    "goodpart": "node_modules/.bin/goodparts *",
    "playwright": " npx playwright install --with-deps && npx playwright test",
    "storybook": "storybook dev -p 6006 --no-open",
    "serve": "http-server dist --port 9002 -P http://localhost:9002?",
    "build-storybook": "storybook build",
    "smoke": "playwright test --config=playwright.smoke.config.ts",
    "smoke:storybook": "playwright test --config=playwright.storybook.config.ts",
    "generate-openapi-services": "openapi-generator-cli generate -i api-docs.json -g typescript-axios -o src/api/generated --additional-properties=useSingleRequestParameter=true,stringEnums=true,supportsES6=true"
  },
