{
    "compilerOptions": {
        "outDir": "./dist/",
        "sourceMap": true,
        "strict": true,
        "noImplicitAny": true,
        "module": "esnext",
        "target": "es2018",
        "jsx": "react",
        "allowJs": true,
        "esModuleInterop": true,
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "allowSyntheticDefaultImports": true,
        "paths": {
            "@components/*": [
                "./src/components/*"
            ],
            "@common/*": [
                "./src/common/*"
            ],
            "@pages/*": [
                "./src/pages/*"
            ],
            "@api/*": [
                "./src/api/*"
            ]
        }
    }
}
